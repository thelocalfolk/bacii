        "pp_body_4": {
          "type": "text",
          "name": "Body",
          "settings": {
            "text": "<p>We use the following tools to understand behaviour and improve our marketing:</p><ul><li>Shopify (our ecommerce platform)</li><li>Klaviyo (email and SMS marketing)</li><li>Meta Pixel (Facebook &amp; Instagram advertising)</li><li>Google Analytics</li></ul><p>These tools may collect data such as:</p><ul><li>Pages viewed</li><li>Products viewed</li><li>Add-to-cart activity</li><li>Purchases</li><li>Interactions with ads and emails</li></ul>",
            "width": "fill",
