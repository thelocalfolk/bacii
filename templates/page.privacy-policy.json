        "pp_body_2": {
          "type": "text",
          "name": "Body",
          "settings": {
            "text": "<p>When you visit our website, we automatically collect:</p><ul><li>IP address</li><li>Browser type and device information</li><li>Time zone</li><li>Pages viewed, time spent, and referring websites</li></ul><p>This helps us understand how customers interact with our store and improve performance.</p>",
            "width": "fill",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "rte",
