

{%- doc -%}
  Decorative animated sticker/decal.

  Renders a positioned, optionally-animated image over its parent section
  (hero, media-with-content, etc.). Purely decorative: pointer-events are
  disabled so it never blocks clicks, and motion is paused for visitors who
  prefer reduced motion.

  Image source priority: uploaded image (image_picker) first, otherwise a
  theme asset filename (e.g. "sticker-mint-star.svg").
{%- enddoc -%}

{% liquid
  assign s = block.settings
  assign flip_scale = 1
  if s.flip_horizontal
    assign flip_scale = -1
  endif
%}

{%- capture sticker_img -%}
  {%- if s.image != blank -%}
    {{ s.image | image_url: width: 600 | image_tag: widths: '150, 300, 450, 600', alt: '', loading: 'lazy', class: 'bacii-sticker__img' }}
  {%- elsif s.asset_filename != blank -%}
    {% # theme-check-disable ImgWidthAndHeight %}
    <img src="{{ s.asset_filename | asset_url }}" alt="" loading="lazy" class="bacii-sticker__img">
    {% # theme-check-enable ImgWidthAndHeight %}
  {%- endif -%}
{%- endcapture -%}

{%- assign sticker_img_stripped = sticker_img | strip -%}
{%- if sticker_img_stripped != '' -%}
  <div
    class="bacii-sticker{% if s.hide_on_mobile %} bacii-sticker--hide-mobile{% endif %}{% if s.mobile_inflow %} bacii-sticker--mobile-flow{% endif %}{% if s.hero_fullbleed %} bacii-sticker--hero{% endif %}"
    style="
      --sticker-size: {{ s.size }}px;
      --sticker-x: {{ s.pos_x }}%;
      --sticker-y: {{ s.pos_y }}%;
      --sticker-size-m: {{ s.size_mobile | default: s.size }}px;
      --sticker-x-m: {{ s.pos_x_mobile | default: s.pos_x }}%;
      --sticker-y-m: {{ s.pos_y_mobile | default: s.pos_y }}%;
      --sticker-rotate: {{ s.rotate }}deg;
      --sticker-flip: {{ flip_scale }};
    "
    {{ block.shopify_attributes }}
  >
    <div
      class="bacii-sticker__inner"
      style="{% if s.animation != 'none' %}animation: bacii-sticker-{{ s.animation }} {{ s.speed }}s ease-in-out infinite;{% endif %}"
    >
      {{ sticker_img }}
      {%- if s.text != blank -%}
        <span
          class="bacii-sticker__caption"
          style="color: {{ s.text_color }}; font-size: {{ s.text_size }}px;"
        >{{ s.text }}</span>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  /* Anchors to the nearest positioned ancestor. In generic sections that is
     `.section` (full-width band, already position:relative in base.css); in the
     hero it is `.hero__content-wrapper`. Positions are therefore % of the whole
     band, so a sticker can sit outside the text column (e.g. bottom-centre). */

  /* Hero full-bleed: the hero renders blocks inside `.hero__content-wrapper`
     (page-width, content-height), so by default a sticker can't reach the full
     hero image. Neutralising that wrapper's positioning lets the sticker anchor
     to `.hero__container` (the full-bleed hero) instead. Content layout is
     unaffected — it's placed by grid + flex, not by this position. */
  .hero__content-wrapper:has(> .bacii-sticker--hero) {
    position: static;
  }

  .bacii-sticker {
    position: absolute;
    top: var(--sticker-y);
    left: var(--sticker-x);
    width: var(--sticker-size);
    transform: translate(-50%, -50%) rotate(var(--sticker-rotate)) scaleX(var(--sticker-flip));
    pointer-events: none;
    z-index: 5;
  }

  .bacii-sticker__inner {
    position: relative;
    transform-origin: center 70%;
    will-change: transform;
  }

  .bacii-sticker__caption {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 20%;
    font-family: var(--font-heading--family, inherit);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: 0.5px;
    pointer-events: none;
  }

  .bacii-sticker__img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 749px) {
    .bacii-sticker {
      top: var(--sticker-y-m);
      left: var(--sticker-x-m);
      width: var(--sticker-size-m);
    }

    /* In-flow mode: sit below the section content instead of overlaying it.
       The flex content wrapper centres it and its gap provides the breathing
       room; the band grows to fit so nothing overlaps the paragraph. */
    .bacii-sticker--mobile-flow {
      position: static;
      top: auto;
      left: auto;
      width: var(--sticker-size-m);
      margin-block-start: var(--sticker-flow-gap, 24px);
      transform: rotate(var(--sticker-rotate)) scaleX(var(--sticker-flip));
    }

    .bacii-sticker--hide-mobile {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bacii-sticker__inner {
      animation: none !important;
    }
  }

  @keyframes bacii-sticker-sway {
    0%, 100% { transform: rotate(-5deg) translateY(0); }
    50%      { transform: rotate(5deg) translateY(-6px); }
  }
  @keyframes bacii-sticker-wiggle {
    0%, 100% { transform: rotate(-6deg); }
    50%      { transform: rotate(6deg); }
  }
  @keyframes bacii-sticker-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-16px); }
  }
  @keyframes bacii-sticker-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.09); }
  }
  @keyframes bacii-sticker-jelly {
    0%, 100% { transform: scale(1, 1); }
    30%      { transform: scale(1.08, 0.92); }
    60%      { transform: scale(0.94, 1.06); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sticker",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Uploaded image"
    },
    {
      "type": "text",
      "id": "asset_filename",
      "label": "Or theme asset filename",
      "info": "Used when no image is uploaded above. e.g. sticker-mint-star.svg",
      "default": "sticker-mint-star.svg"
    },
    {
      "type": "header",
      "content": "Caption (optional)",
      "info": "Overlays text centred on the sticker, e.g. for speech-bubble decals."
    },
    {
      "type": "text",
      "id": "text",
      "label": "Caption text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Caption colour",
      "default": "#fcf5ef"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Caption size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Placement"
    },
    {
      "type": "range",
      "id": "size",
      "label": "Size",
      "min": 40,
      "max": 400,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "pos_x",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 88
    },
    {
      "type": "range",
      "id": "pos_y",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 16
    },
    {
      "type": "range",
      "id": "rotate",
      "label": "Rotation",
      "min": -45,
      "max": 45,
      "step": 1,
      "unit": "deg",
      "default": -8
    },
    {
      "type": "checkbox",
      "id": "flip_horizontal",
      "label": "Flip horizontally",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hero_fullbleed",
      "label": "Anchor to full hero",
      "info": "Turn on when this sticker is inside a Hero section so position is measured against the whole hero image, not the text column.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Mobile placement",
      "info": "Overrides the values above on screens under 750px. Leave at defaults to reuse the desktop placement."
    },
    {
      "type": "checkbox",
      "id": "mobile_inflow",
      "label": "Place below content on mobile",
      "info": "Sits the sticker beneath the section content (in normal flow) instead of overlaying it, so the section grows to make room. Horizontal/vertical position are ignored in this mode.",
      "default": false
    },
    {
      "type": "range",
      "id": "size_mobile",
      "label": "Size (mobile)",
      "min": 40,
      "max": 400,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "pos_x_mobile",
      "label": "Horizontal position (mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "pos_y_mobile",
      "label": "Vertical position (mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Motion"
    },
    {
      "type": "select",
      "id": "animation",
      "label": "Animation",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "sway", "label": "Sway" },
        { "value": "wiggle", "label": "Wiggle" },
        { "value": "float", "label": "Float" },
        { "value": "pulse", "label": "Pulse" },
        { "value": "jelly", "label": "Jelly" }
      ],
      "default": "sway"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed (seconds per loop)",
      "min": 1,
      "max": 6,
      "step": 0.5,
      "unit": "s",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Sticker"
    }
  ]
}
{% endschema %}
