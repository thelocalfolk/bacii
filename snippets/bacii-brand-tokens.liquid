{% doc %}
  Bacii brand design tokens — all named colours and type fine-tuning.
  Rendered once in theme.liquid after color-palette.liquid.
{% enddoc %}
{% style %}
  :root {
    /* Brand colours */
    --color-cream:       #FCF5EF;
    --color-dark-grey:   #59697A;
    --color-blue:        #007DFE;
    --color-coral:       #FF835D;
    --color-mint:        #7BD8B3;
    --color-butter:      #FFECA8;
    --color-bubblegum:   #F5A8B8;
    --color-periwinkle:  #C9BCF4;
    --color-tiffany:     #D8F9F2;

    /* Type scale — exact Figma values */
    --font-size-h1: 60px;
    --line-height-h1: 1.0;
    --letter-spacing-h1: 0.02em;

    --font-size-h2: 30px;
    --line-height-h2: 1.15;
    --letter-spacing-h2: 0.02em;

    --font-size-h4: 22px;
    --line-height-h4: 25px;
    --letter-spacing-h4: 0.02em;

    --font-size-h5: 17px;
    --line-height-h5: 20px;
    --letter-spacing-h5: 0.02em;

    --font-size-btn: 18px;
    --line-height-btn: 1.5;
    --letter-spacing-btn: 0.02em;

    --font-size-link: 14px;
    --line-height-link: 33px;

    --font-size-body-1: 15px;
    --line-height-body-1: 1.5;

    --font-size-body-2: 12px;
    --line-height-body-2: 1.55;

    /* Button & input shape */
    --btn-radius: 28px;
    --input-radius: 1000px;

    /* Page max-width */
    --page-max-width: 1440px;
  }

  /* Apply exact heading sizes — Horizon's token steps don't map 1:1 */
  h1, .h1 { font-size: var(--font-size-h1); line-height: var(--line-height-h1); letter-spacing: var(--letter-spacing-h1); }
  h2, .h2 { font-size: var(--font-size-h2); line-height: var(--line-height-h2); letter-spacing: var(--letter-spacing-h2); }
  h4, .h4 { font-size: var(--font-size-h4); line-height: var(--line-height-h4); letter-spacing: var(--letter-spacing-h4); }
  h5, .h5 { font-size: var(--font-size-h5); line-height: var(--line-height-h5); letter-spacing: var(--letter-spacing-h5); }


  {%- comment -%}
    Homepage hero only — cream gradient over the left of the photo for text readability.
    Scoped to the index template so page/product/collection heroes are controlled by their
    own overlay setting instead of this hardcoded gradient.
  {%- endcomment -%}
  {%- if template.name == 'index' -%}
  /* Hero — cream gradient over the left half of the photo only */
  .hero .hero__media-grid::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--color-cream) 12%, rgba(252,245,239,0.75) 27%, transparent 42%);
    pointer-events: none;
    z-index: 1;
  }

  /* Hero content sits above the gradient overlay */
  .hero .hero__content-wrapper {
    position: relative;
    z-index: 2;
  }

  /* Homepage hero heading — slightly larger on small screens. The heading uses
     clamp(2.125rem, 7.2vw, 4.5rem); on phones 7.2vw falls below the floor, so it
     was pinned at 34px. Raise only the floor (desktop max 72px is unchanged). */
  .hero .h1 {
    --font-h1--size: clamp(2.5rem, 7.2vw, 4.5rem);
  }
  {%- endif -%}

  /* Pill nav header — cream capsule floating over the page at all scroll states */
  .header-section {
    background-color: transparent !important;
    padding-block: 12px;
  }

  #header-component .header__columns,
  #header-component[transparent] .header__columns,
  #header-component[data-sticky-state] .header__columns {
    background-color: var(--color-cream) !important;
    border-radius: 1000px !important;
    padding-inline: 24px;
    margin-inline: 48px;
  }

  /* Cart count bubble — keep it dark-on-cream in EVERY header state.
     Horizon only colours the bubble in the non-sticky transparent state, so on
     scroll (sticky) it fell back to a colour that vanished on our always-cream
     pill. Pin it on .header__row; the transparent-state rule (higher specificity)
     still wins at the top of the page, so the top state is unchanged. */
  #header-component .header__row {
    --cart-bubble-background: var(--color-dark-grey);
    --cart-bubble-text: var(--color-cream);
  }

  /* Mobile: anchor the pill (smaller side margins) and shorten its height */
  @media screen and (max-width: 749px) {
    .header-section {
      padding-block: 4px;
    }

    #header-component .header__columns,
    #header-component[transparent] .header__columns,
    #header-component[data-sticky-state] .header__columns {
      padding-inline: 16px;
      padding-block: 6px !important;
      margin-inline: 12px;
    }
  }

  {%- comment -%} Inner-page heroes: compact content-fit height via padding; shrink oversized heading and clear the floating pill on mobile {%- endcomment -%}
  {%- unless template.name == 'index' -%}
  .hero .hero__content-wrapper {
    padding-block-start: 48px;
    padding-block-end: 16px;
  }

  /* Hero height on desktop is controlled by the section's "Height = Custom"
     slider (see hero.liquid .hero--custom-height, which makes the slider
     authoritative and clips the image band to that height). Here we only
     position the text below the floating header pill; we do NOT force a
     fixed height, so the slider works. */
  @media screen and (min-width: 750px) {
    .hero .hero__container {
      align-items: flex-start !important;
    }
    .hero .hero__content-wrapper {
      padding-block-start: 120px;
    }
  }

  @media screen and (max-width: 749px) {
    .hero h1,
    .hero .h1 {
      font-size: 38px;
      line-height: 1.05;
    }

    .hero .hero__content-wrapper {
      padding-block-start: 84px;
      padding-block-end: 24px;
    }
  }
  {%- endunless -%}

  /* True pill radius on inputs (Horizon schema caps at 32 via settings) */
  input[type="email"],
  input[type="text"],
  input[type="search"],
  .field__input,
  .newsletter-form__field-wrapper input {
    border-radius: var(--input-radius) !important;
  }
{% endstyle %}
