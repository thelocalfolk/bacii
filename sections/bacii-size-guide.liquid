{%- comment -%}
  Bacii — Size guide page section.
  Thin wrapper (background, width, padding) around the shared size-guide content
  snippet, so the page and the PDP lightbox render an identical design.
  Component styles live in assets/custom.css (.bacii-sizeguide*).
{%- endcomment -%}

<div
  class="bacii-sizeguide section"
  style="
    background: {{ section.settings.background_color }};
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="bacii-sizeguide__pad">
    {% render 'bacii-size-guide',
      heading: section.settings.heading,
      intro: section.settings.intro,
      heading_color: section.settings.heading_color,
      text_color: section.settings.text_color,
      content_width: section.settings.content_width
    %}
  </div>
</div>

{% stylesheet %}
  .bacii-sizeguide__pad {
    padding-inline: 24px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Size guide",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Guide"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Available in sizes 1–6,</p><p>True age sizing with a relaxed fit.</p>"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#007DFE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#59697A"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FCF5EF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Padding top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 140
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Size guide"
    }
  ]
}
{% endschema %}
