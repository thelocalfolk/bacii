{%- comment -%}
  Bacii Club — centred heading + subtext, with an area below for the Tolstoy
  video app block. Add the Tolstoy widget via Add block → (app). Background is a
  per-section setting so the homepage and PDP instances can differ.
{%- endcomment -%}

<div
  class="bacii-club section section--{{ section.settings.section_width }}"
  style="
    background: {{ section.settings.background_color }};
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="bacii-club__head">
    {%- if section.settings.heading != blank -%}
      <h2 class="bacii-club__heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="bacii-club__sub" style="color: {{ section.settings.text_color }};">
        {{ section.settings.subtext }}
      </p>
    {%- endif -%}
  </div>

  <div class="bacii-club__media">
    {% content_for 'blocks' %}
    {%- if request.design_mode and section.blocks.size == 0 -%}
      <p class="bacii-club__placeholder">
        Add your Tolstoy video block here — “Add block” → the Tolstoy app.
      </p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .bacii-club__head {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  .bacii-club__heading {
    margin: 0 0 12px;
  }

  .bacii-club__sub {
    margin: 0;
    font-family: var(--font-body--family);
  }

  .bacii-club__media {
    margin-block-start: 40px;
  }

  .bacii-club__placeholder {
    text-align: center;
    padding: 48px 24px;
    margin: 0 24px;
    border: 1px dashed rgba(89, 105, 122, 0.4);
    border-radius: 16px;
    color: var(--color-dark-grey, #59697a);
    font-family: var(--font-body--family);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "The Bacii Club",
  "tag": "section",
  "blocks": [{ "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Bacii Club"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Real families, real kids and lots of big personalities."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#007DFE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtext colour",
      "default": "#59697A"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFECA8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    { "name": "The Bacii Club" }
  ]
}
{% endschema %}
